# Stryda Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Database — Render Postgres connection string (or leave blank for SQLite in dev)
DATABASE_URL=postgresql://user:password@host:5432/stryda

# JWT secret — generate a strong random string for production
SECRET_KEY=stryda-dev-secret-key-change-in-production

# CORS — comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173,http://localhost:3000
# Production: https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
